<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Launcher Flotante de Widgets"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Un launcher minimalista que flota sobre cualquier app"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="16dp"/>

    <Button
        android:id="@+id/btn_request_permission"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Conceder permiso de overlay"
        android:layout_margin="8dp"/>

    <Button
        android:id="@+id/btn_configure"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. Configurar widgets"
        android:layout_margin="8dp"/>

    <Button
        android:id="@+id/btn_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3. Iniciar Launcher Flotante"
        android:layout_margin="8dp"/>

</LinearLayout>