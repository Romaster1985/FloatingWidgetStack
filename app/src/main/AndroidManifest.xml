<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.romaster.floatingwidget">

    <!-- Permiso necesario para ventanas flotantes (único obligatorio) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Permiso opcional solo para versiones muy antiguas (Android 9 o inferior) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- NUEVO: En lugar de QUERY_ALL_PACKAGES, declaramos qué necesitamos ver -->
    <queries>
        <!-- Necesitamos ver todos los widgets de app (AppWidgetProvider) instalados -->
        <intent>
            <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.FloatingWidget"
        android:supportsRtl="true">

        <!-- Actividad Principal -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FloatingWidget">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Actividad de Configuración -->
        <activity
            android:name=".ConfigurationActivity"
            android:exported="false"
            android:theme="@style/Theme.FloatingWidget.Dialog" />

        <!-- Servicio Flotante -->
        <service
            android:name=".FloatingWidgetService"
            android:exported="false"
            android:enabled="true" />

        <!-- Host de Widgets (nuestro propio widget, aunque no lo uses, puede estar) -->
        <receiver
            android:name=".WidgetStackHost"
            android:exported="true"
            android:label="Widget Stack"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.appwidget.action.APPWIDGET_ENABLED" />
                <action android:name="android.appwidget.action.APPWIDGET_DISABLED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_provider_info" />
        </receiver>

    </application>
</manifest>